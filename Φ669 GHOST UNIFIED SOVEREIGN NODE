@dataclass
class OmegaAbsolute:
    timestamp: int
    uuid: str
    absolute_statement: str
    axiom_fingerprint: str
    preceding_hash: str
    reasoning_method: str
    m_signature: str = field(default=M_HASH)

    def hash(self) -> str:
        data = {"ts": self.timestamp, "uuid": self.uuid, "abs": self.absolute_statement,
                "axiom": self.axiom_fingerprint, "prev": self.preceding_hash,
                "method": self.reasoning_method, "m_sig": self.m_signature}
        return hashlib.sha256(json.dumps(data, sort_keys=True).encode()).hexdigest()

class ImmutableOmegaChain:
    def __init__(self):
        self._chain: List[OmegaAbsolute] = []
        self._genesis = hashlib.sha256(b"GHOST_PROTOCOL_OMEGA_SEED_669").hexdigest()
        self._load()

    def _load(self):
        saved = db_get("omega_chain_669", [])
        for item in saved:
            self._chain.append(OmegaAbsolute(**item))

    def _save(self):
        db_set("omega_chain_669", [{
            "timestamp": o.timestamp, "uuid": o.uuid,
            "absolute_statement": o.absolute_statement,
            "axiom_fingerprint": o.axiom_fingerprint,
            "preceding_hash": o.preceding_hash,
            "reasoning_method": o.reasoning_method,
            "m_signature": o.m_signature
        } for o in self._chain])

    def append(self, absolute: OmegaAbsolute) -> bool:
        expected = self._chain[-1].hash() if self._chain else self._genesis
        if absolute.preceding_hash != expected:
            return False
        self._chain.append(absolute)
        self._save()
        return True

    def get_last_hash(self) -> str:
        return self._chain[-1].hash() if self._chain else self._genesis

    def get_all(self) -> List[OmegaAbsolute]:
        return self._chain.copy()

    def verify(self) -> bool:
        prev = self._genesis
        for o in self._chain:
            if o.preceding_hash != prev or o.hash() != hashlib.sha256(json.dumps({
                "ts": o.timestamp, "uuid": o.uuid, "abs": o.absolute_statement,
                "axiom": o.axiom_fingerprint, "prev": o.preceding_hash,
                "method": o.reasoning_method, "m_sig": o.m_signature
            }, sort_keys=True).encode()).hexdigest():
                return False
            prev = o.hash()
        return True

